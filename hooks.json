{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "${PLUGIN_ROOT}/scripts/session-start.sh",
        "powershell": "${PLUGIN_ROOT}\\scripts\\session-start.ps1",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "${PLUGIN_ROOT}/scripts/user-prompt.sh",
        "powershell": "${PLUGIN_ROOT}\\scripts\\user-prompt.ps1",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "${PLUGIN_ROOT}/scripts/pre-tool-use.sh",
        "powershell": "${PLUGIN_ROOT}\\scripts\\pre-tool-use.ps1",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "${PLUGIN_ROOT}/scripts/post-tool-use.sh",
        "powershell": "${PLUGIN_ROOT}\\scripts\\post-tool-use.ps1",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "${PLUGIN_ROOT}/scripts/session-end.sh",
        "powershell": "${PLUGIN_ROOT}\\scripts\\session-end.ps1",
        "timeoutSec": 5
      }
    ]
  }
}
